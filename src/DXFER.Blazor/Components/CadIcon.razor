@namespace DXFER.Blazor.Components

<svg class="@CssClass"
     width="20"
     height="20"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="1.8"
     stroke-linecap="round"
     stroke-linejoin="round"
     aria-hidden="true"
     focusable="false">
    @switch (Name)
    {
        case CadIconName.FolderOpen:
            <path d="M3.5 7.5V18a2 2 0 0 0 2 2h13a2 2 0 0 0 2-2v-7.8a2 2 0 0 0-2-2h-7.2l-2-2H5.5a2 2 0 0 0-2 2Z" />
            <path d="M3.5 10.5h17" />
            break;
        case CadIconName.Sample:
            <path d="M5 4.5h8l4 4V19a1.5 1.5 0 0 1-1.5 1.5h-10A1.5 1.5 0 0 1 4 19V6a1.5 1.5 0 0 1 1.5-1.5Z" />
            <path d="M13 4.5V9h4" />
            <path d="M8 14h6" />
            <path d="M11 11v6" />
            break;
        case CadIconName.Export:
            <path d="M12 3v11" />
            <path d="m7.5 9.5 4.5 4.5 4.5-4.5" />
            <path d="M5 18.5h14" />
            <path d="M5 21h14" />
            break;
        case CadIconName.CollapseLeft:
            <path d="M4 5h16" />
            <path d="M4 19h16" />
            <path d="M8 5v14" />
            <path d="m15 9-3 3 3 3" />
            break;
        case CadIconName.CollapseRight:
            <path d="M4 5h16" />
            <path d="M4 19h16" />
            <path d="M16 5v14" />
            <path d="m9 9 3 3-3 3" />
            break;
        case CadIconName.Select:
            <path d="M5 3.5 18.5 14 12 15.2 9.1 21 5 3.5Z" />
            <path d="m13 14 4.5 4.5" />
            break;
        case CadIconName.Measure:
            <path d="m16 3 5 5L8 21l-5-5L16 3Z" />
            <path d="m14 5 2 2" />
            <path d="m11.5 7.5 2 2" />
            <path d="m9 10 2 2" />
            <path d="m6.5 12.5 2 2" />
            break;
        case CadIconName.Undo:
            <path d="m9 14-5-5 5-5" />
            <path d="M4 9h10.5A5.5 5.5 0 0 1 20 14.5v0A5.5 5.5 0 0 1 14.5 20H11" />
            break;
        case CadIconName.Redo:
            <path d="m15 14 5-5-5-5" />
            <path d="M20 9H9.5A5.5 5.5 0 0 0 4 14.5v0A5.5 5.5 0 0 0 9.5 20H13" />
            break;
        case CadIconName.Line:
            <path d="M5 19 19 5" />
            <circle cx="5" cy="19" r="1.5" />
            <circle cx="19" cy="5" r="1.5" />
            break;
        case CadIconName.CenterLine:
            <path d="M4 12h16" stroke-dasharray="4 3" />
            <path d="M12 5v14" stroke-dasharray="4 3" />
            break;
        case CadIconName.Rectangle:
            <path d="M5 6h14v12H5z" />
            <circle cx="5" cy="6" r="1" />
            <circle cx="19" cy="18" r="1" />
            break;
        case CadIconName.CenterRectangle:
            <path d="M5 6h14v12H5z" />
            <path d="M12 9v6" />
            <path d="M9 12h6" />
            break;
        case CadIconName.Circle:
            <circle cx="12" cy="12" r="7" />
            <circle cx="12" cy="12" r="1.4" />
            break;
        case CadIconName.ThreePointCircle:
            <circle cx="12" cy="12" r="7" />
            <circle cx="7" cy="8" r="1" />
            <circle cx="17" cy="8" r="1" />
            <circle cx="12" cy="19" r="1" />
            break;
        case CadIconName.Arc:
            <path d="M6 16a8 8 0 0 1 12-8" />
            <circle cx="6" cy="16" r="1.2" />
            <circle cx="18" cy="8" r="1.2" />
            <circle cx="12" cy="7" r="1.2" />
            break;
        case CadIconName.Slot:
            <path d="M8 7h8a5 5 0 0 1 0 10H8A5 5 0 0 1 8 7Z" />
            <path d="M8 12h8" />
            break;
        case CadIconName.Trim:
            <path d="M5 19 19 5" />
            <path d="M6 6h8" />
            <path d="M10 3v6" />
            break;
        case CadIconName.Extend:
            <path d="M5 17h7" />
            <path d="M12 17h7" stroke-dasharray="2 3" />
            <path d="m16 14 3 3-3 3" />
            break;
        case CadIconName.Split:
            <path d="M5 12h6" />
            <path d="M13 12h6" />
            <path d="M12 7v10" />
            break;
        case CadIconName.Offset:
            <path d="M6 17c4-1 7-4 10-10" />
            <path d="M9 20c4-1 8-5 11-11" />
            break;
        case CadIconName.Fillet:
            <path d="M6 18h5a7 7 0 0 0 7-7V6" />
            <path d="M6 6v12h12" opacity="0.35" />
            break;
        case CadIconName.Chamfer:
            <path d="M6 18h5l7-7V6" />
            <path d="M6 6v12h12" opacity="0.35" />
            break;
        case CadIconName.Move:
            <path d="M12 3v18" />
            <path d="M3 12h18" />
            <path d="m12 3 3 3" />
            <path d="m12 3-3 3" />
            <path d="m21 12-3-3" />
            <path d="m21 12-3 3" />
            <path d="m12 21 3-3" />
            <path d="m12 21-3-3" />
            <path d="M3 12l3-3" />
            <path d="M3 12l3 3" />
            break;
        case CadIconName.Rotate:
            <path d="M18 8a6 6 0 1 0 1 7" />
            <path d="M18 4v4h-4" />
            break;
        case CadIconName.Scale:
            <path d="M5 19 19 5" />
            <path d="M14 5h5v5" />
            <path d="M5 14v5h5" />
            break;
        case CadIconName.Mirror:
            <path d="M12 4v16" stroke-dasharray="3 3" />
            <path d="m5 17 4-10v10H5Z" />
            <path d="m19 17-4-10v10h4Z" />
            break;
        case CadIconName.LinearPattern:
            <circle cx="6" cy="12" r="2" />
            <circle cx="12" cy="12" r="2" />
            <circle cx="18" cy="12" r="2" />
            <path d="M4 6h16" />
            break;
        case CadIconName.CircularPattern:
            <path d="M18 12a6 6 0 1 1-2-4.5" />
            <path d="M18 6v6h-6" />
            <circle cx="12" cy="12" r="1.2" />
            <circle cx="16" cy="16" r="1.2" />
            <circle cx="8" cy="16" r="1.2" />
            break;
        case CadIconName.Fit:
            <path d="M8 3H4.5A1.5 1.5 0 0 0 3 4.5V8" />
            <path d="M16 3h3.5A1.5 1.5 0 0 1 21 4.5V8" />
            <path d="M21 16v3.5a1.5 1.5 0 0 1-1.5 1.5H16" />
            <path d="M8 21H4.5A1.5 1.5 0 0 1 3 19.5V16" />
            <path d="M8 8h8v8H8z" />
            break;
        case CadIconName.BoundsToOrigin:
            <path d="M4 20V5" />
            <path d="M4 20h15" />
            <path d="M8 16h8V8H8z" />
            <path d="m8 16-4 4" />
            break;
        case CadIconName.PointToOrigin:
            <path d="M4 20V5" />
            <path d="M4 20h15" />
            <circle cx="14" cy="10" r="3" />
            <path d="m12 12-8 8" />
            break;
        case CadIconName.OriginAxes:
            <path d="M12 4v16" stroke-dasharray="2 3" />
            <path d="M4 12h16" stroke-dasharray="2 3" />
            <circle cx="12" cy="12" r="2" />
            break;
        case CadIconName.VectorToX:
            <path d="M4 17h16" />
            <path d="m16 13 4 4-4 4" />
            <path d="M6 6l5 5" />
            <path d="m11 6-5 5" />
            break;
        case CadIconName.VectorToY:
            <path d="M7 20V4" />
            <path d="m3 8 4-4 4 4" />
            <path d="M15 6l2.5 4L20 6" />
            <path d="M17.5 10v4" />
            break;
        case CadIconName.LongBoundsToX:
            <path d="M4 14h16" />
            <path d="m16 10 4 4-4 4" />
            <path d="M5 6h9v4H5z" />
            break;
        case CadIconName.LongBoundsToY:
            <path d="M10 20V4" />
            <path d="m6 8 4-4 4 4" />
            <path d="M14 10h4v9h-4z" />
            break;
    }
</svg>

@code {
    [Parameter]
    public CadIconName Name { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private string CssClass => string.IsNullOrWhiteSpace(Class)
        ? "dxfer-icon"
        : $"dxfer-icon {Class}";
}

@namespace DXFER.Blazor.Components

@foreach (var group in Groups)
{
    <details class="dxfer-tool-section dxfer-tool-section-collapsible" open="@group.InitiallyOpen">
        <summary class="dxfer-tool-section-summary">
            <span class="dxfer-tool-section-heading">
                <span class="dxfer-section-title">@group.Name</span>
                @if (!string.IsNullOrWhiteSpace(group.Label))
                {
                    <span class="dxfer-tool-section-label">@group.Label</span>
                }
            </span>
            <span class="dxfer-tool-section-count">@group.Commands.Count</span>
        </summary>
        <div class="dxfer-command-strip" role="toolbar" aria-label="@($"{group.Name} tools")">
            @foreach (var command in group.Commands)
            {
                <CadIconButton Icon="@command.Icon"
                               Label="@command.Label"
                               Tooltip="@command.TooltipText"
                               Hotkey="@command.Hotkey"
                               Disabled="@command.Disabled"
                               Pressed="@command.Pressed"
                               Class="@BuildCommandClass(command)"
                               OnClick="@(() => OnCommandInvoked.InvokeAsync(command.Id))" />
            }
        </div>
    </details>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<WorkbenchToolGroup> Groups { get; set; } = Array.Empty<WorkbenchToolGroup>();

    [Parameter]
    public EventCallback<WorkbenchCommandId> OnCommandInvoked { get; set; }

    private static string? BuildCommandClass(WorkbenchToolCommand command)
    {
        var classes = new List<string>();
        if (command.IsFuture)
        {
            classes.Add("dxfer-icon-button-future");
        }

        if (command.IsConfirmedWorking)
        {
            classes.Add("dxfer-icon-button-confirmed");
        }

        return classes.Count == 0 ? null : string.Join(" ", classes);
    }
}

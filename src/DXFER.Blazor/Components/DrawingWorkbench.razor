@namespace DXFER.Blazor.Components

<div class="dxfer-workbench">
    <aside class="dxfer-tool-panel" aria-label="DXFER prep tools">
        <section class="dxfer-tool-section">
            <div class="dxfer-section-title">File</div>
            <div class="dxfer-command-strip" role="toolbar" aria-label="File tools">
                <label class="dxfer-file-picker" title="Open DXF or DWG">
                    <CadIcon Name="@CadIconName.FolderOpen" />
                    <span>Open</span>
                    <InputFile OnChange="OpenFileAsync"
                               accept=".dxf,.dwg"
                               class="dxfer-file-input"
                               style="position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;" />
                </label>
                <CadIconButton Icon="@CadIconName.Sample"
                               Label="Load sample drawing"
                               OnClick="LoadSample" />
                <CadIconButton Icon="@CadIconName.Export"
                               Label="Export DXF text"
                               Disabled="@(!HasDocument)"
                               OnClick="GenerateDxfExport" />
            </div>
        </section>

        <section class="dxfer-tool-section">
            <div class="dxfer-section-title">Tools</div>
            <div class="dxfer-command-strip" role="toolbar" aria-label="CAD tools">
                <CadIconButton Icon="@CadIconName.Select"
                               Label="Select"
                               Pressed="@(_activeTool == WorkbenchTool.Select)"
                               OnClick="ActivateSelectTool" />
                <CadIconButton Icon="@CadIconName.Measure"
                               Label="Measure"
                               Pressed="@(_activeTool == WorkbenchTool.Measure)"
                               OnClick="ActivateMeasureTool" />
                <CadIconButton Icon="@CadIconName.Undo"
                               Label="Undo"
                               Disabled="@(!CanUndo)"
                               OnClick="UndoLastDocumentChange" />
                <CadIconButton Icon="@CadIconName.Redo"
                               Label="Redo"
                               Disabled="@(!CanRedo)"
                               OnClick="RedoLastDocumentChange" />
            </div>
        </section>

        <section class="dxfer-tool-section">
            <div class="dxfer-section-title">Fit</div>
            <div class="dxfer-command-strip" role="toolbar" aria-label="Fit and origin tools">
                <CadIconButton Icon="@CadIconName.Fit"
                               Label="Fit extents"
                               Disabled="@(!HasDocument)"
                               OnClick="FitAsync" />
                <CadIconButton Icon="@CadIconName.BoundsToOrigin"
                               Label="Move bounds minimum to origin"
                               Disabled="@(!HasDocument)"
                               OnClick="MoveBoundsToOrigin" />
                <CadIconButton Icon="@CadIconName.PointToOrigin"
                               Label="Move selected point to origin"
                               Disabled="@(!CanMoveSelectedPointToOrigin)"
                               OnClick="MoveSelectedPointToOrigin" />
            </div>
        </section>

        <section class="dxfer-tool-section">
            <div class="dxfer-section-title">View</div>
            <div class="dxfer-command-strip" role="toolbar" aria-label="View tools">
                <CadIconButton Icon="@CadIconName.OriginAxes"
                               Label="Origin axes"
                               Tooltip="Toggle dotted global origin axes. X is red; Y is green."
                               Pressed="@_showOriginAxes"
                               OnClick="ToggleOriginAxes" />
            </div>
        </section>

        <section class="dxfer-tool-section">
            <div class="dxfer-section-title">Align</div>
            <div class="dxfer-command-strip" role="toolbar" aria-label="Alignment tools">
                <CadIconButton Icon="@CadIconName.VectorToX"
                               Label="Align selected vector to X"
                               Disabled="@(!CanAlignSelectedVector)"
                               OnClick="AlignSelectedVectorToX" />
                <CadIconButton Icon="@CadIconName.VectorToY"
                               Label="Align selected vector to Y"
                               Disabled="@(!CanAlignSelectedVector)"
                               OnClick="AlignSelectedVectorToY" />
                <CadIconButton Icon="@CadIconName.LongBoundsToX"
                               Label="Orient long bounds to X"
                               Disabled="@(!HasDocument)"
                               OnClick="OrientLongAxisToX" />
                <CadIconButton Icon="@CadIconName.LongBoundsToY"
                               Label="Orient long bounds to Y"
                               Disabled="@(!HasDocument)"
                               OnClick="OrientLongAxisToY" />
            </div>
        </section>

        <section class="dxfer-tool-section">
            <div class="dxfer-section-title">Grain</div>
            <label class="dxfer-radio">
                <input type="radio" name="grain-direction" checked="@(_grainDirection == GrainDirection.None)" @onchange="() => SetGrainDirection(GrainDirection.None)" />
                <span>No grain</span>
            </label>
            <label class="dxfer-radio">
                <input type="radio" name="grain-direction" checked="@(_grainDirection == GrainDirection.GlobalX)" @onchange="() => SetGrainDirection(GrainDirection.GlobalX)" />
                <span>Global X</span>
            </label>
            <label class="dxfer-radio">
                <input type="radio" name="grain-direction" checked="@(_grainDirection == GrainDirection.GlobalY)" @onchange="() => SetGrainDirection(GrainDirection.GlobalY)" />
                <span>Global Y</span>
            </label>
        </section>
    </aside>

    <main class="dxfer-canvas-panel">
        <DrawingCanvas @ref="_canvas"
                       Document="_document"
                       ShowToolbar="false"
                       ShowOriginAxes="_showOriginAxes"
                       GrainDirection="_grainDirection"
                       SelectionResetToken="_selectionResetToken"
                       HoveredEntityChanged="OnHoveredEntityChanged"
                       SelectionChanged="OnSelectionChanged" />
    </main>

    <aside class="dxfer-inspector" aria-label="Drawing inspector">
        <section class="dxfer-inspector-section">
            <div class="dxfer-section-title">Status</div>
            <div class="dxfer-file-name">@_fileName</div>
            <div class="dxfer-status">@_status</div>
        </section>

        <section class="dxfer-inspector-section">
            <div class="dxfer-section-title">Selection</div>
            <dl class="dxfer-metrics">
                <dt>Hover</dt>
                <dd>@HoverText</dd>
                <dt>Selected</dt>
                <dd>@_selectedEntityIds.Count</dd>
                <dt>Measure</dt>
                <dd>@MeasurementText</dd>
            </dl>
        </section>

        <section class="dxfer-inspector-section">
            <div class="dxfer-section-title">Bounds</div>
            <dl class="dxfer-metrics">
                <dt>X</dt>
                <dd>@FormatRange(Bounds.MinX, Bounds.MaxX)</dd>
                <dt>Y</dt>
                <dd>@FormatRange(Bounds.MinY, Bounds.MaxY)</dd>
                <dt>Size</dt>
                <dd>@FormatSize(Bounds.Width, Bounds.Height)</dd>
            </dl>
        </section>

        <section class="dxfer-inspector-section dxfer-metadata-section">
            <div class="dxfer-section-title">Sync Metadata</div>
            <pre class="dxfer-metadata">@MetadataJson</pre>
        </section>

        @if (!string.IsNullOrWhiteSpace(_exportText))
        {
            <section class="dxfer-inspector-section dxfer-export-section">
                <div class="dxfer-section-title">DXF Export</div>
                <textarea class="dxfer-export-text" readonly>@_exportText</textarea>
            </section>
        }
    </aside>
</div>

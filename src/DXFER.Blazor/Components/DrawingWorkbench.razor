@namespace DXFER.Blazor.Components

<div class="@WorkbenchCssClass" style="@WorkbenchGridStyle">
    @if (_isToolPanelCollapsed)
    {
        <button type="button"
                class="dxfer-dock-tab dxfer-dock-tab-left"
                title="Show tool palette"
                aria-label="Show tool palette"
                @onclick="ToggleToolPanel">
            <CadIcon Name="@CadIconName.CollapseRight" />
        </button>
    }
    else
    {
    <aside class="dxfer-tool-panel" aria-label="DXFER prep tools">
        <div class="dxfer-dock-header">
            <div>
                <div class="dxfer-section-title">Tools</div>
                <div class="dxfer-dock-subtitle">Grouped CAD palette</div>
            </div>
            <CadIconButton Icon="@CadIconName.CollapseLeft"
                           Label="Collapse tool palette"
                           OnClick="ToggleToolPanel" />
        </div>

        <WorkbenchToolPalette Groups="@ToolGroups" OnCommandInvoked="InvokeWorkbenchCommand" />

        <details class="dxfer-tool-section dxfer-tool-section-collapsible" open>
            <summary class="dxfer-tool-section-summary">
                <span class="dxfer-section-title">Grain</span>
            </summary>
            <label class="dxfer-radio">
                <input type="radio" name="grain-direction" checked="@(_grainDirection == GrainDirection.None)" @onchange="() => SetGrainDirection(GrainDirection.None)" />
                <span>No grain</span>
            </label>
            <label class="dxfer-radio">
                <input type="radio" name="grain-direction" checked="@(_grainDirection == GrainDirection.GlobalX)" @onchange="() => SetGrainDirection(GrainDirection.GlobalX)" />
                <span>Global X</span>
            </label>
            <label class="dxfer-radio">
                <input type="radio" name="grain-direction" checked="@(_grainDirection == GrainDirection.GlobalY)" @onchange="() => SetGrainDirection(GrainDirection.GlobalY)" />
                <span>Global Y</span>
            </label>
        </details>

        @if (IsParametricCommandActive)
        {
            <section class="dxfer-command-panel" aria-label="Command parameters">
                <div class="dxfer-command-panel-title">@ActiveToolLabel</div>
                <label>
                    <span>Distance</span>
                    <input type="number" placeholder="0.000" disabled />
                </label>
                <label>
                    <span>Angle</span>
                    <input type="number" placeholder="0.000" disabled />
                </label>
            </section>
        }
    </aside>
    }

    @if (!_isToolPanelCollapsed)
    {
        <button type="button"
                class="dxfer-panel-resizer dxfer-panel-resizer-left"
                title="Resize tool palette"
                aria-label="Resize tool palette"
                @onpointerdown="BeginToolPanelResize"
                @onpointerdown:preventDefault="true" />
    }

    <main class="dxfer-canvas-panel">
        <DrawingCanvas @ref="_canvas"
                       Document="_document"
                       ShowToolbar="false"
                       DocumentFitToken="_documentFitToken"
                       ActiveTool="_activeTool"
                       ShowOriginAxes="_showOriginAxes"
                       GrainDirection="_grainDirection"
                       ConstructionMode="_constructionMode"
                       SelectionResetToken="_selectionResetToken"
                       HoveredEntityChanged="OnHoveredEntityChanged"
                       SelectionChanged="OnSelectionChanged"
                       ActiveSelectionChanged="OnActiveSelectionChanged"
                       ToolCommitRequested="OnToolCommitRequested"
                       ToolModeChanged="OnCanvasToolModeChanged"
                       SplitAtPointRequested="OnSplitAtPointRequested"
                       ConstructionToggleRequested="OnConstructionToggleRequested"
                       ToolCancelRequested="OnToolCanceled"
                       SketchDimensionValueChanged="OnSketchDimensionValueChanged"
                       SketchDimensionAnchorChanged="OnSketchDimensionAnchorChanged"
                       SketchDimensionPlacementRequested="OnSketchDimensionPlacementRequested"
                       DeleteSelectionRequested="DeleteSelectedGeometry" />
    </main>

    @if (_isInspectorCollapsed)
    {
        <button type="button"
                class="dxfer-dock-tab dxfer-dock-tab-right"
                title="Show inspector"
                aria-label="Show inspector"
                @onclick="ToggleInspector">
            <CadIcon Name="@CadIconName.CollapseLeft" />
        </button>
    }
    else
    {
    <aside class="dxfer-inspector" aria-label="Drawing inspector">
        <div class="dxfer-dock-header">
            <div>
                <div class="dxfer-section-title">Inspector</div>
                <div class="dxfer-dock-subtitle">Debug and Sync detail</div>
            </div>
            <CadIconButton Icon="@CadIconName.CollapseRight"
                           Label="Collapse inspector"
                           OnClick="ToggleInspector" />
        </div>
        <section class="dxfer-inspector-section">
            <div class="dxfer-section-title">Status</div>
            <div class="dxfer-file-name">@_fileName</div>
            <div class="dxfer-status">@_status</div>
        </section>

        <section class="dxfer-inspector-section">
            <div class="dxfer-section-title">Selection</div>
            <dl class="dxfer-metrics">
                <dt>Hover</dt>
                <dd>@HoverText</dd>
                <dt>Selected</dt>
                <dd>@_selectedEntityIds.Count</dd>
                <dt>Measure</dt>
                <dd>@MeasurementText</dd>
            </dl>
        </section>

        <section class="dxfer-inspector-section">
            <div class="dxfer-section-title">Bounds</div>
            <dl class="dxfer-metrics">
                <dt>X</dt>
                <dd>@FormatRange(Bounds.MinX, Bounds.MaxX)</dd>
                <dt>Y</dt>
                <dd>@FormatRange(Bounds.MinY, Bounds.MaxY)</dd>
                <dt>Size</dt>
                <dd>@FormatSize(Bounds.Width, Bounds.Height)</dd>
            </dl>
        </section>

        <section class="dxfer-inspector-section dxfer-metadata-section">
            <div class="dxfer-section-title">Sync Metadata</div>
            <pre class="dxfer-metadata">@MetadataJson</pre>
        </section>

        @if (!string.IsNullOrWhiteSpace(_exportText))
        {
            <section class="dxfer-inspector-section dxfer-export-section">
                <div class="dxfer-section-title">DXF Export</div>
                <textarea class="dxfer-export-text" readonly>@_exportText</textarea>
            </section>
        }
    </aside>
    }

    @if (!_isInspectorCollapsed)
    {
        <button type="button"
                class="dxfer-panel-resizer dxfer-panel-resizer-right"
                title="Resize inspector"
                aria-label="Resize inspector"
                @onpointerdown="BeginInspectorResize"
                @onpointerdown:preventDefault="true" />
    }

    <footer class="dxfer-command-bar" aria-label="Command and measurement readout">
        <div class="dxfer-command-prompt">@CommandPromptText</div>
        <div class="dxfer-command-chips" aria-label="Live measurement readout">
            @foreach (var item in LiveMeasurementReadouts)
            {
                <div class="dxfer-live-readout-item">
                    <span class="dxfer-live-readout-label">@item.Label</span>
                    <span class="dxfer-live-readout-value">@item.Value</span>
                </div>
            }
        </div>
    </footer>

    @if (_resizeTarget is not DockResizeTarget.None)
    {
        <div class="dxfer-resize-capture"
             @onpointermove="OnWorkbenchPointerMove"
             @onpointerup="EndDockPanelResize"
             @onpointercancel="EndDockPanelResize"
             @onpointerleave="EndDockPanelResize"></div>
    }
</div>
